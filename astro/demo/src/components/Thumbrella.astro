---
// Thumbrella.astro — page-level coordinator for Thumbnail components.
//
// All <Thumbnail> elements on the page batch-load through a single
// streaming request.  Place this once in your layout; <Thumbnail>
// components anywhere on the page will use it automatically.
//
// Usage (global — once in layout):
//   <Thumbrella connect="tbr_p_XXXX" />
//
// Connect is optional — without it, the client reads TBR_CONNECT from
// the environment.  Use a publishable key (tbr_p_ prefix) when the
// connect string appears in client-side HTML.  Secret keys (tbr_s_)
// should only be used in server-side code.
//
// Usage (scoped — for pages that need a different server):
//   <Thumbrella connect="http://staging:8001#secret">
//     <Thumbnail src="..." />
//   </Thumbrella>

interface Props {
  /** Connection string.  Prefer a publishable key (tbr_p_) when set in HTML. */
  connect?: string;
}

const { connect } = Astro.props;
---

{/* The wrapper <div> is a no-op visually — it just provides a hook for */}
{/* scoped usage.  The init script scans the whole page regardless. */}
<div data-tbr-root>
  <slot />
</div>

<script>
  import { initThumbnails } from "@thumbrella/astro";

  // requestAnimationFrame ensures all child components have rendered
  // their [data-tbr-url] elements before the scan runs.
  requestAnimationFrame(() => {
    initThumbnails("{connect}");
  });
</script>
