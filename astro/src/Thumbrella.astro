---
// Thumbrella.astro — scoped coordinator for <Thumbnail> components.
//
//   <Thumbrella connect="https://demo.thumbrella.dev">
//     <Thumbnail src="https://demo.thumbrella.dev/media/apollo-exterior.glb" />
//     <Thumbnail src="https://demo.thumbrella.dev/media/raw-pentax.pef" />
//   </Thumbrella>
//
// Thumbnail components are intended to be grouped inside a Thumbrella
// component. This allows them to share configuration and be handled in
// streaming batches, instead of individually. The thumbnails are not
// required to be immediately children.
//
// The primary attribute is the `connect`, which defines the server and/or
// api keys needed to access a Thumbrella server.
//
// NOTICE,
// Be aware that the thumbnails will be resolved by browsers at viewing time.
// This will make the server address or keys publically available to any user.
// Thumbrella keys can be restricted to certain addresses and their own usage
// quotas. Be sure any key used here is being handled appropriately.


interface Props {
  /** Connection string.  Prefer a publishable key (tbr_p_) in HTML. */
  connect?: string;
  /**
   * Only load thumbnails when they scroll into view.
   * Individual <Thumbnail> elements can override with their own lazyLoad prop.
   */
  lazyLoad?: boolean;
}

const { connect, lazyLoad } = Astro.props;
const rootId = `tbr-${crypto.randomUUID().slice(0, 8)}`;
---

<div data-tbr-root id={rootId} data-tbr-connect={connect || ""} data-tbr-lazy={lazyLoad ? "true" : undefined}>
  <slot />
</div>

<script>
  import { initThumbnails } from "./browser.ts";

  for (const el of document.querySelectorAll('[data-tbr-root]:not([data-tbr-init])')) {
    if (el instanceof HTMLElement) {
      const c = el.dataset.tbrConnect;
      const lazy = el.dataset.tbrLazy === "true";
      requestAnimationFrame(() => {
        initThumbnails(el, c || undefined, lazy);
      });
    }
  }
</script>
