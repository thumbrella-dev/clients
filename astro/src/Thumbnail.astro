---
// Thumbnail.astro - Show a thumbnail for any media.
//
// Thumbnail components are intended to be grouped inside a Thumbrella
// component. This allows them to share configuration and be handled in
// streaming batches, instead of individually. The thumbnails are not
// required to be immediately children.
// 
// Longer rendering thumbnails will show temporarily use placeholder images
// until finished. Every thumbnail component will show an image, even if
// configuration completely fails or the server cannot be reached. 

interface Props {
  /** Media URL to thumbnail. */
  src: string;
  /** Alt text. */
  alt?: string;
  /** CSS class(es). */
  class?: string;
  /** Override parent Thumbrella lazy-load setting for this item. */
  lazyLoad?: boolean;
}

const { src, alt = "", class: className = "", lazyLoad } = Astro.props;

const placeholder = "data:image/svg+xml," + encodeURIComponent(
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 4 3"><rect fill="#e0e0e0" width="4" height="3"/></svg>`,
);
---

<div
  class={`tbr-wrap ${className}`.trim() || undefined}
  data-tbr-url={src}
  data-tbr-lazy={lazyLoad != null ? String(lazyLoad) : undefined}
>
  <img
    class="tbr-placeholder"
    src={placeholder}
    alt={alt}
    loading="lazy"
    decoding="async"
  />
  <img
    class="tbr-final"
    src=""
    alt=""
    loading="lazy"
    decoding="async"
  />
  <div class="tbr-spinner" aria-hidden="true"></div>
</div>

<style>
  .tbr-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #0d1225;
    overflow: hidden;
  }
  .tbr-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tbr-final {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .tbr-loaded .tbr-final {
    opacity: 1;
  }

  .tbr-spinner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 2;
  }
  .tbr-spinner::after {
    content: "";
    width: 22px;
    height: 22px;
    border: 3px solid #1e2d50;
    border-top-color: #e94560;
    border-radius: 50%;
    animation: tbr-spin 0.8s linear infinite;
  }
  @keyframes tbr-spin {
    to { transform: rotate(360deg); }
  }
  .tbr-requested .tbr-spinner,
  .tbr-intermediate .tbr-spinner {
    opacity: 1;
  }
  .tbr-loaded .tbr-spinner {
    opacity: 0;
  }
</style>
